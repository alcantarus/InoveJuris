# App Environment (production or test)
NEXT_PUBLIC_APP_ENV=test

# Supabase Configuration
# Option 1: Separate Environments (Recommended)
# Production
NEXT_PUBLIC_SUPABASE_URL_PROD=
NEXT_PUBLIC_SUPABASE_ANON_KEY_PROD=
# Test
NEXT_PUBLIC_SUPABASE_URL_TEST=
NEXT_PUBLIC_SUPABASE_ANON_KEY_TEST=

# Option 2: Single Environment (Fallback)
# If you only have one Supabase project, you can use these standard variables.
# They will be used for BOTH production and test environments if the specific ones above are missing.
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Datajud API Configuration
DATAJUD_API_KEY=

# Email OAuth2 Configuration
# Google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Outlook / Microsoft
OUTLOOK_CLIENT_ID=
OUTLOOK_CLIENT_SECRET=

# Gemini API
NEXT_PUBLIC_GEMINI_API_KEY=
